{
  "dependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@szum-tech/design-system": "^3.21.9",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tailwindcss/postcss": "^4.3.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "next": "^16.2.9",
    "next-compose-plugins": "^2.2.1",
    "next-themes": "^0.4.6",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.1",
    "@chromatic-com/storybook": "^5.0.0",
    "@playwright/test": "^1.61.1",
    "@storybook-community/storybook-dark-mode": "^7.1.3",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@szum-tech/semantic-release-config": "^2.3.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "playwright": "^1.56.0",
    "semantic-release": "^25.0.5",
    "serve": "^14.2.5",
    "storybook": "^10.4.1",
    "storybook-addon-tag-badges": "^3.0.4",
    "tailwindcss": "^4.1.11",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "name": "nextjs-szumplate",
  "private": true,
  "scripts": {
    "analyze": "ANALYZE=true npm run build",
    "biome:check": "biome check .",
    "biome:ci": "biome ci --reporter=github",
    "biome:fix": "biome check --write .",
    "biome:format": "biome format .",
    "biome:format:fix": "biome format --write .",
    "biome:lint": "biome lint .",
    "biome:lint:fix": "biome lint --write .",
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "storybook:build": "storybook build",
    "storybook:dev": "storybook dev -p 6006",
    "storybook:serve": "serve storybook-static",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest --coverage",
    "test:coverage": "vitest --coverage --passWithNoTests",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:ci": " playwright test --pass-with-no-tests",
    "test:e2e:ui": "playwright test --ui --pass-with-no-tests",
    "test:storybook": "vitest --project=storybook --coverage --passWithNoTests",
    "test:storybook:coverage": "vitest run --project=storybook --coverage.enabled --coverage.reportsDirectory=coverage-storybook",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run --project=unit --passWithNoTests",
    "test:unit:coverage": "vitest run --project=unit --coverage.enabled --coverage.reportsDirectory=coverage-unit",
    "test:watch": "vitest watch --passWithNoTests",
    "type-check": "next typegen && tsc --noEmit"
  },
  "type": "module",
  "version": "0.0.0"
}
