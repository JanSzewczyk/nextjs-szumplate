{
  "name": "nextjs-szumplate",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "analyze": "ANALYZE=true bun run build",
    "build": "bun --bun next build",
    "dev": "bun --bun next dev",
    "lint": "bun run eslint .",
    "lint:ci": "bun run eslint . -o eslint-results.sarif -f @microsoft/eslint-formatter-sarif",
    "lint:fix": "bun run eslint --fix .",
    "prettier:check": "bun run prettier --check .",
    "prettier:write": "bun run prettier --write .",
    "start": "bun --bun next start",
    "storybook:build": "bun run storybook build",
    "storybook:dev": "bun run storybook dev -p 6006",
    "storybook:serve": "bun run serve storybook-static",
    "test": "bun run vitest run --passWithNoTests",
    "test:ci": "CI=true bun run vitest --coverage",
    "test:coverage": "bun run vitest --coverage --passWithNoTests",
    "test:e2e": "bun run playwright test --pass-with-no-tests",
    "test:e2e:ci": "CI=true bun run playwright test --pass-with-no-tests",
    "test:e2e:ui": "bun run playwright test --ui --pass-with-no-tests",
    "test:storybook": "bun run vitest --project=storybook --coverage --passWithNoTests",
    "test:ui": "bun run vitest --ui",
    "test:unit": "bun run vitest --project=unit --coverage --passWithNoTests",
    "test:watch": "bun run vitest watch --passWithNoTests",
    "type-check": "bun run next typegen && bun run tsc --noEmit"
  },
  "dependencies": {
    "@next/bundle-analyzer": "^16.1.4",
    "@szum-tech/design-system": "^3.11.1",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tailwindcss/postcss": "^4.1.14",
    "babel-plugin-react-compiler": "^1.0.0",
    "next": "^16.1.4",
    "next-compose-plugins": "^2.2.1",
    "next-themes": "^0.4.6",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@chromatic-com/storybook": "^5.0.0",
    "@playwright/test": "^1.58.0",
    "@storybook-community/storybook-dark-mode": "^7.1.0",
    "@storybook/addon-a11y": "^10.2.0",
    "@storybook/addon-docs": "^10.2.0",
    "@storybook/addon-vitest": "^10.2.0",
    "@storybook/nextjs-vite": "^10.2.0",
    "@szum-tech/eslint-config": "^2.2.2",
    "@szum-tech/prettier-config": "^1.6.2",
    "@szum-tech/semantic-release-config": "^2.3.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.16",
    "eslint": "^10.0.3",
    "playwright": "^1.56.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.0",
    "serve": "^14.2.5",
    "storybook": "^10.1.11",
    "storybook-addon-tag-badges": "^3.0.4",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.16"
  }
}
